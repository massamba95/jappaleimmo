# ============================================================================
# Jappalé Immo — variables d'environnement
# ----------------------------------------------------------------------------
# Copier ce fichier en .env.local et remplir les valeurs.
# Les variables préfixées NEXT_PUBLIC_ sont exposées au navigateur.
# Les autres sont des secrets serveur — ne jamais les commit.
# ============================================================================

# --- Supabase (base de données + auth + storage) ---------------------------
# Créer un projet sur https://supabase.com, puis récupérer dans Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
# Clé admin (bypass RLS) — utilisée côté serveur uniquement (crons, admin)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# --- Resend (emails transactionnels) ----------------------------------------
# Créer un compte sur https://resend.com, ajouter le domaine jappaleimmo.com
# Les mails sont signés avec DKIM via resend._domainkey.jappaleimmo.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Crons (Vercel) ---------------------------------------------------------
# Token partagé — vérifié par les routes /api/cron/* pour rejeter les appels
# externes. Vercel envoie ce secret dans le header Authorization.
CRON_SECRET=une-longue-chaine-aleatoire-au-moins-32-caracteres

# --- Paiements (Wave / Orange Money) ---------------------------------------
# Numéros marchands affichés sur la page /dashboard/upgrade
NEXT_PUBLIC_WAVE_PHONE=+221770000000
NEXT_PUBLIC_OM_PHONE=+221770000000

# --- Scripts Playwright (dev seulement — PAS en prod) ----------------------
# Ces variables vont dans .env.local.screenshots (déjà gitignoré).
# Utilisées par scripts/screenshots.mjs, scripts/pdfs.mjs, scripts/brochure.mjs
# DEMO_BASE_URL=https://www.jappaleimmo.com
# DEMO_ADMIN_EMAIL=compte-demo@exemple.com
# DEMO_ADMIN_PASSWORD=motdepasse
